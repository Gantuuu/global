{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/navigation/**",
              "components/product/**",
              "components/web/**",
              "ui_kits/app/**",
              "ui_kits/web/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Pretendard))/i]",
        "message": "Font not provided by the design system. Available: Pretendard."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|variant|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, variant, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:sale|instant|guarantee|best|new|neutral|free)$/]",
        "message": "<Badge> tone must be one of 'sale' | 'instant' | 'guarantee' | 'best' | 'new' | 'neutral' | 'free'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:soft|solid)$/]",
        "message": "<Badge> variant must be one of 'soft' | 'solid'."
      },
      {
        "selector": "JSXOpeningElement[name.name='BottomNav'] > JSXAttribute > JSXIdentifier[name!=/^(?:active|onChange|style|key|ref|className|style|children)$/]",
        "message": "<BottomNav> doesn't accept that prop. Declared props: active, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='BottomNav'] > JSXAttribute[name.name='active'] > Literal[value!=/^(?:home|trip|deal|community|my)$/]",
        "message": "<BottomNav> active must be one of 'home' | 'trip' | 'deal' | 'community' | 'my'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|size|block|disabled|iconLeft|iconRight|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: tone, size, block, disabled, iconLeft, iconRight, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:primary|brand|secondary|ghost)$/]",
        "message": "<Button> tone must be one of 'primary' | 'brand' | 'secondary' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg|xl)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg' | 'xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CategoryTile'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|image|label|badge|shape|key|ref|className|style|children)$/]",
        "message": "<CategoryTile> doesn't accept that prop. Declared props: icon, image, label, badge, shape."
      },
      {
        "selector": "JSXOpeningElement[name.name='CategoryTile'] > JSXAttribute[name.name='shape'] > Literal[value!=/^(?:tile|circle)$/]",
        "message": "<CategoryTile> shape must be one of 'tile' | 'circle'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|count|selected|key|ref|className|style|children)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: label, count, selected."
      },
      {
        "selector": "JSXOpeningElement[name.name='CouponCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|label|amount|suffix|onDownload|key|ref|className|style|children)$/]",
        "message": "<CouponCard> doesn't accept that prop. Declared props: icon, label, amount, suffix, onDownload."
      },
      {
        "selector": "JSXOpeningElement[name.name='GnbCategory'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|label|ad|key|ref|className|style|children)$/]",
        "message": "<GnbCategory> doesn't accept that prop. Declared props: icon, label, ad."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|placeholder|variant|iconLeft|style|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: value, onChange, placeholder, variant, iconLeft, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:search|box)$/]",
        "message": "<Input> variant must be one of 'search' | 'box'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProductBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|variant|label|key|ref|className|style|children)$/]",
        "message": "<ProductBadge> doesn't accept that prop. Declared props: tone, variant, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProductBadge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:sale|instant|guarantee|best|new|neutral)$/]",
        "message": "<ProductBadge> tone must be one of 'sale' | 'instant' | 'guarantee' | 'best' | 'new' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProductBadge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:soft|solid)$/]",
        "message": "<ProductBadge> variant must be one of 'soft' | 'solid'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Rating'] > JSXAttribute > JSXIdentifier[name!=/^(?:score|count|size|key|ref|className|style|children)$/]",
        "message": "<Rating> doesn't accept that prop. Declared props: score, count, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='Rating'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Rating> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='RegionCircle'] > JSXAttribute > JSXIdentifier[name!=/^(?:image|label|selected|onClick|key|ref|className|style|children)$/]",
        "message": "<RegionCircle> doesn't accept that prop. Declared props: image, label, selected, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeader'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|subtitle|action|onAction|size|key|ref|className|style|children)$/]",
        "message": "<SectionHeader> doesn't accept that prop. Declared props: title, subtitle, action, onAction, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeader'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:lg|md)$/]",
        "message": "<SectionHeader> size must be one of 'lg' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TopBarAction'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|label|onClick|key|ref|className|style|children)$/]",
        "message": "<TopBarAction> doesn't accept that prop. Declared props: icon, label, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='WebProductBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|label|variant|key|ref|className|style|children)$/]",
        "message": "<WebProductBadge> doesn't accept that prop. Declared props: tone, label, variant."
      },
      {
        "selector": "JSXOpeningElement[name.name='WebProductBadge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:sale|instant|guarantee|best|new|neutral|free)$/]",
        "message": "<WebProductBadge> tone must be one of 'sale' | 'instant' | 'guarantee' | 'best' | 'new' | 'neutral' | 'free'."
      },
      {
        "selector": "JSXOpeningElement[name.name='WebProductBadge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:soft|solid)$/]",
        "message": "<WebProductBadge> variant must be one of 'soft' | 'solid'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
